#!/usr/bin/env node

const fs = require('fs')
const path = require('path')

const args = process.argv.slice(2)

if (args.length < 2) {
  console.error('Usage: add-article <topic-name> <markdown-file.md>')
  console.error('Example: add-article Design my-article.md')
  process.exit(1)
}

const [categoryArg, mdFilePath] = args

const resolvedMdPath = path.resolve(process.cwd(), mdFilePath)
if (!fs.existsSync(resolvedMdPath)) {
  console.error(`Error: File not found: ${resolvedMdPath}`)
  process.exit(1)
}

const rawContent = fs.readFileSync(resolvedMdPath, 'utf-8')

function parseFrontmatter(raw) {
  const match = raw.match(/^---\r?\n([\s\S]*?)\r?\n---\r?\n?([\s\S]*)$/)
  if (!match) {
    console.error('Error: Markdown file must begin with frontmatter delimited by ---')
    console.error('See scripts/template.md for the expected format.')
    process.exit(1)
  }

  const frontmatterStr = match[1]
  const body = match[2].trim()

  const frontmatter = {}
  for (const line of frontmatterStr.split(/\r?\n/)) {
    const colonIdx = line.indexOf(':')
    if (colonIdx === -1) continue
    const key = line.slice(0, colonIdx).trim()
    const value = line.slice(colonIdx + 1).trim()
    if (key) frontmatter[key] = value
  }

  return { frontmatter, body }
}

const { frontmatter, body } = parseFrontmatter(rawContent)

if (!frontmatter.title) {
  console.error('Error: frontmatter must include a "title" field')
  process.exit(1)
}
if (!frontmatter.excerpt) {
  console.error('Error: frontmatter must include an "excerpt" field')
  process.exit(1)
}

function toSlug(title) {
  return title
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '')
}

function formatDate(d) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
}

const title    = frontmatter.title
const excerpt  = frontmatter.excerpt
const slug     = frontmatter.slug  || toSlug(title)
const date     = frontmatter.date  || formatDate(new Date())
const category = categoryArg.charAt(0).toUpperCase() + categoryArg.slice(1)

const paragraphs = body
  .split(/\n{2,}/)
  .map(p => p.replace(/\n/g, ' ').trim())
  .filter(p => p.length > 0)

if (paragraphs.length === 0) {
  console.error('Error: No body paragraphs found. Separate paragraphs with a blank line.')
  process.exit(1)
}

function esc(str) {
  return str.replace(/\\/g, '\\\\').replace(/"/g, '\\"')
}

const contentLines = paragraphs.map(p => `      "${esc(p)}",`).join('\n')

const postBlock = `  {
    title: "${esc(title)}",
    excerpt:
      "${esc(excerpt)}",
    date: "${esc(date)}",
    slug: "${esc(slug)}",
    category: "${esc(category)}",
    content: [
${contentLines}
    ],
  },`

const postsFilePath = path.resolve(__dirname, '..', 'lib', 'posts.ts')
if (!fs.existsSync(postsFilePath)) {
  console.error(`Error: Could not find lib/posts.ts at: ${postsFilePath}`)
  process.exit(1)
}

const postsContent = fs.readFileSync(postsFilePath, 'utf-8')

const marker = 'const posts: Post[] = ['
const markerIdx = postsContent.indexOf(marker)
if (markerIdx === -1) {
  console.error('Error: Could not find "const posts: Post[] = [" in lib/posts.ts')
  process.exit(1)
}

const insertAt = markerIdx + marker.length
const updated  = postsContent.slice(0, insertAt) + '\n' + postBlock + '\n' + postsContent.slice(insertAt)

fs.writeFileSync(postsFilePath, updated, 'utf-8')

console.log('')
console.log('Article added to lib/posts.ts (as featured post)')
console.log('')
console.log('  Title:    ' + title)
console.log('  Topic:    ' + category)
console.log('  Slug:     ' + slug)
console.log('  Date:     ' + date)
console.log('  URL:      /post/' + slug)
console.log('')
